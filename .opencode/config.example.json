{
  "$schema": "https://opencode.ai/schemas/config.json",
  "providers": {
    "anthropic": {
      "apiKey": "${ANTHROPIC_API_KEY}"
    }
  },
  "agents": {
    "coder": {
      "model": "claude-sonnet-4-20250514",
      "maxTokens": 8000
    }
  },
  "mcpServers": {
    "c4": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "${C4_INSTALL_DIR}", "run", "python", "-m", "c4.mcp_server"],
      "env": {
        "C4_PROJECT_ROOT": "${PWD}"
      }
    }
  }
}

# =============================================================================
# C4 Environment Configuration
# Copy this file to .env and fill in the values
# cp .env.example .env
# =============================================================================

# ─── Store Backend ────────────────────────────────────────────
# Options: sqlite (default), local_file, supabase
C4_STORE_BACKEND=sqlite

# ─── Supabase (required for cloud features) ───────────────────
# Create a project at https://supabase.com and get these values
# Get from: https://supabase.com/dashboard/project/_/settings/api
C4_SUPABASE_URL=https://your-project.supabase.co
C4_SUPABASE_KEY=eyJ...your-anon-key...

# ─── Team & RLS (optional, for multi-tenancy) ─────────────────
# Team ID for Row Level Security isolation
# Get from: SELECT id FROM teams WHERE name = 'your-team-name';
# C4_TEAM_ID=your-team-uuid

# Supabase Auth JWT token (for RLS policy enforcement)
# Get from: Supabase Auth after user login
# SUPABASE_ACCESS_TOKEN=your-jwt-token

# ─── C5 Hub Server (optional, for distributed job queue) ──────
C5_HUB_URL=http://localhost:8585
C5_API_KEY=

# ─── OAuth (optional, for user authentication) ────────────────
# GITHUB_CLIENT_ID=your-oauth-app-client-id
# GITHUB_CLIENT_SECRET=your-oauth-app-client-secret

# GitHub personal access token for auto-commit and PR creation
# Get from: https://github.com/settings/tokens (needs repo scope)
# GITHUB_TOKEN=ghp_xxxxx

# ─── LLM Providers (optional, for c4_llm_call) ───────────────
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# ─── Economic Presets ─────────────────────────────────────────
# Options: standard, economic, ultra-economic, quality, economic-thinking
# C4_ECONOMIC_PRESET=standard

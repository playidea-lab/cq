# C4 Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# =============================================================================
# Store Backend Configuration
# =============================================================================

# Store backend: sqlite (default), local_file, supabase
C4_STORE_BACKEND=sqlite

# =============================================================================
# Supabase Configuration (required when C4_STORE_BACKEND=supabase)
# =============================================================================

# Supabase project URL
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in client apps)
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_KEY=your-anon-key

# =============================================================================
# Team & RLS Configuration (optional, for multi-tenancy)
# =============================================================================

# Team ID for Row Level Security isolation
# Get from: SELECT id FROM teams WHERE name = 'your-team-name';
# C4_TEAM_ID=your-team-uuid

# Supabase Auth JWT token (for RLS policy enforcement)
# Get from: Supabase Auth after user login
# SUPABASE_ACCESS_TOKEN=your-jwt-token

# =============================================================================
# LLM Configuration (optional)
# =============================================================================

# OpenAI API Key (for gpt-4o, etc.)
# OPENAI_API_KEY=sk-...

# Anthropic API Key (for claude-3-opus, etc. - separate from Claude Code subscription)
# ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# =============================================================================
# GitHub Integration (optional)
# =============================================================================

# GitHub personal access token for auto-commit and PR creation
# Get from: https://github.com/settings/tokens (needs repo scope)
# GITHUB_TOKEN=ghp_xxxxx

# GitHub OAuth (for token refresh with Supabase Auth)
# GITHUB_CLIENT_ID=your-oauth-app-client-id
# GITHUB_CLIENT_SECRET=your-oauth-app-client-secret

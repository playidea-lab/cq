      "Bash(docker-compose:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "Write(/Users/changmin/git/c4/**)",
      "Edit(/Users/changmin/git/c4/**)",
      "MultiEdit(/Users/changmin/git/c4/**)",
      "Read(/Users/changmin/git/c4/**)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "Bash|Read|Edit|Write|MultiEdit|NotebookEdit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/permission-reviewer.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(echo \"$ARGUMENTS\" | jq -r '.file_path // empty') && if [[ \"$FILE\" == *.go ]]; then cd \"$(git rev-parse --show-toplevel)\" && go build ./... 2>&1 | head -20; fi",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "FILE=$(echo \"$ARGUMENTS\" | jq -r '.file_path // empty') && if [[ \"$FILE\" == *.py ]]; then python -m py_compile \"$FILE\"; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
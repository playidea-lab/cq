{
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/c4-permission-reviewer.sh",
            "timeout": 20,
            "type": "command"
          }
        ],
        "matcher": "Bash|Read|Edit|Write|NotebookEdit|WebFetch|WebSearch|Search|Skill"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "FILE=$(echo \"$ARGUMENTS\" | jq -r '.file_path // empty') \u0026\u0026 if [[ \"$FILE\" == *.go ]]; then ROOT=$(git rev-parse --show-toplevel) \u0026\u0026 cd \"$ROOT\" \u0026\u0026 go build ./... 2\u003e\u00261 | head -20 \u0026\u0026 go vet ./... 2\u003e\u00261 | head -20; fi",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": "FILE=$(echo \"$ARGUMENTS\" | jq -r '.file_path // empty') \u0026\u0026 if [[ \"$FILE\" == *.py ]]; then uv run python -m py_compile \"$FILE\" 2\u003e\u00261; fi",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/c4-gate.sh",
            "type": "command"
          }
        ],
        "matcher": "Bash|Edit|Write"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Skill(c4-*)",
      "Skill(c9-*)",
      "Skill(pi)",
      "Skill(research-loop)",
      "Skill(cycle-*)",
      "Skill(simplify)",
      "mcp__cq__*",
      "mcp__worker-*__*",
      "mcp__piq__*",
      "mcp__serena__*",
      "mcp__plugin_serena_serena__*",
      "Bash(uv:*)",
      "Bash(pip:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(cargo:*)",
      "Bash(go:*)",
      "Bash(cd:*)",
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(ls:*)",

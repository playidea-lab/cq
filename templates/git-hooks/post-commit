#!/bin/bash
# C4 Git Hook: post-commit
# Runs tests after commit completion
#
# Features:
# - Attempts to communicate with C4 Daemon via Unix Domain Socket
# - Falls back to direct pytest if Daemon not running
# - Displays warning on test failure (commit already completed)
# - Displays success message on test pass
# - Supports background execution (user setting)

# =============================================================================
# Configuration
# =============================================================================

# C4 Daemon socket path (in .c4 directory)
C4_SOCKET="${C4_SOCKET:-.c4/c4.sock}"

# Test command (fallback if daemon not running)
FALLBACK_TEST_CMD="${C4_TEST_CMD:-uv run pytest tests/unit/ -x -q}"

# Timeout for socket communication (seconds)
SOCKET_TIMEOUT="${C4_SOCKET_TIMEOUT:-5}"

# Test execution timeout (seconds)
TEST_TIMEOUT="${C4_TEST_TIMEOUT:-120}"

# Run tests in background (set to "true" to enable)
C4_POST_COMMIT_BACKGROUND="${C4_POST_COMMIT_BACKGROUND:-false}"

# =============================================================================
# Utility Functions
# =============================================================================

log_info() {
    echo "C4: $1" >&2
}

log_warn() {
    echo "C4 WARNING: $1" >&2
}

log_success() {
    echo "C4 SUCCESS: $1" >&2
}

run_tests_background() {
    # Run tests in background and log results
    local logfile="${C4_LOG_DIR:-.c4/logs}/post-commit-$(date +%Y%m%d-%H%M%S).log"
    mkdir -p "$(dirname "$logfile")"

    {
        echo "=== C4 Post-Commit Tests ==="
        echo "Started: $(date)"
        echo "Commit: $(git rev-parse HEAD)"
        echo ""
        run_tests_foreground
        echo ""
        echo "Finished: $(date)"
    } > "$logfile" 2>&1 &

    log_info "Tests running in background. Check $logfile for results."
}

run_tests_foreground() {
    # Try Unix Domain Socket first, then fallback
    if [[ -S "$C4_SOCKET" ]]; then
        log_info "Connecting to C4 Daemon for test execution..."

        VALIDATION_RESULT=""
        if command -v socat &> /dev/null; then
            VALIDATION_RESULT=$(echo '{"action": "validate", "type": "unit"}' | \
                timeout "$SOCKET_TIMEOUT" socat - "UNIX-CONNECT:$C4_SOCKET" 2>/dev/null || echo "")
        elif command -v nc &> /dev/null && nc -h 2>&1 | grep -q "\-U"; then
            VALIDATION_RESULT=$(echo '{"action": "validate", "type": "unit"}' | \
                timeout "$SOCKET_TIMEOUT" nc -U "$C4_SOCKET" 2>/dev/null || echo "")
        fi

        if [[ -n "$VALIDATION_RESULT" ]]; then
            if echo "$VALIDATION_RESULT" | grep -q '"status":\s*"pass"'; then
                log_success "Tests passed (via Daemon)."
                return 0
            elif echo "$VALIDATION_RESULT" | grep -q '"status":\s*"fail"'; then
                log_warn "Tests failed (via Daemon). Commit has completed, but tests need attention."
                ERROR_MSG=$(echo "$VALIDATION_RESULT" | grep -o '"message":\s*"[^"]*"' | cut -d'"' -f4 || echo "")
                if [[ -n "$ERROR_MSG" ]]; then
                    echo "$ERROR_MSG" >&2
                fi
                return 1
            fi
            log_info "Daemon response unclear, using fallback test runner..."
        else
            log_info "Daemon not responding, using fallback test runner..."
        fi
    else
        log_info "Daemon not running, using fallback test runner..."
    fi

    # Fallback: Direct test execution
    run_fallback_tests
    return $?
}

run_fallback_tests() {
    if command -v uv &> /dev/null; then
        if timeout "$TEST_TIMEOUT" uv run pytest tests/unit/ -x -q 2>/dev/null; then
            log_success "Tests passed."
            return 0
        else
            log_warn "Tests failed. Commit has completed, but tests need attention."
            return 1
        fi
    elif command -v pytest &> /dev/null; then
        if timeout "$TEST_TIMEOUT" pytest tests/unit/ -x -q 2>/dev/null; then
            log_success "Tests passed."
            return 0
        else
            log_warn "Tests failed. Commit has completed, but tests need attention."
            return 1
        fi
    else
        log_info "pytest not found, skipping post-commit tests."
        return 0
    fi
}

# =============================================================================
# Post-commit Check
# =============================================================================

# Skip if not in a C4 project
if [[ ! -f ".c4/state.json" ]] && [[ ! -f ".c4/config.yaml" ]]; then
    exit 0
fi

log_info "Running post-commit tests..."

# =============================================================================
# Execute Tests
# =============================================================================

if [[ "$C4_POST_COMMIT_BACKGROUND" == "true" ]]; then
    run_tests_background
    exit 0  # Always exit 0 for background mode (commit already done)
else
    run_tests_foreground
    # Exit 0 regardless of test result - commit is already complete
    exit 0
fi

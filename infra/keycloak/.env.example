# C4 Keycloak Configuration
# Copy this file to .env and update values for your environment

# ==========================================
# Keycloak Admin Credentials
# ==========================================
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=change-me-in-production

# ==========================================
# PostgreSQL Database
# ==========================================
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=change-me-in-production

# ==========================================
# Keycloak Server Settings
# ==========================================
KC_HOSTNAME=localhost
KC_HOSTNAME_PORT=8080
KC_PORT=8080
KC_LOG_LEVEL=INFO

# ==========================================
# GitHub OAuth (Identity Provider)
# ==========================================
# Create OAuth App at: https://github.com/settings/developers
# Authorization callback URL: http://localhost:8080/realms/c4/broker/github/endpoint
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ==========================================
# Google OAuth (Identity Provider)
# ==========================================
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/realms/c4/broker/google/endpoint
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ==========================================
# C4 API Client Secret (for backend service)
# ==========================================
C4_API_CLIENT_SECRET=change-me-in-production

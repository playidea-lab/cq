{
  "realm": "c4",
  "enabled": true,
  "displayName": "C4 Development Platform",
  "displayNameHtml": "<strong>C4</strong> Development Platform",
  "registrationAllowed": false,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "sslRequired": "external",
  "defaultSignatureAlgorithm": "RS256",
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "actionTokenGeneratedByAdminLifespan": 43200,
  "actionTokenGeneratedByUserLifespan": 300,

  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "C4 Platform Administrator",
        "composite": false
      },
      {
        "name": "supervisor",
        "description": "C4 Supervisor - can review checkpoints and manage tasks",
        "composite": false
      },
      {
        "name": "worker",
        "description": "C4 Worker - can execute assigned tasks",
        "composite": false
      },
      {
        "name": "viewer",
        "description": "C4 Viewer - read-only access to project status",
        "composite": false
      }
    ]
  },

  "defaultRoles": ["viewer"],

  "clients": [
    {
      "clientId": "c4-api",
      "name": "C4 API Backend",
      "description": "Backend API service for C4 platform",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "${C4_API_CLIENT_SECRET:-c4-api-secret-change-me}",
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:3000"
      ],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "publicClient": false,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "300",
        "saml.assertion.signature": "false",
        "saml.force.post.binding": "false",
        "saml.multivalued.roles": "false",
        "saml.encrypt": "false",
        "backchannel.logout.session.required": "true",
        "backchannel.logout.revoke.offline.tokens": "false"
      },
      "protocolMappers": [
        {
          "name": "c4-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "c4-web",
      "name": "C4 Web Dashboard",
      "description": "Frontend SPA for C4 platform dashboard",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:3000/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://localhost:5173"
      ],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "frontchannelLogout": true,
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*##http://localhost:5173/*"
      },
      "protocolMappers": [
        {
          "name": "c4-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "c4-cli",
      "name": "C4 CLI Tool",
      "description": "Command-line interface for C4 platform",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "redirectUris": [
        "http://localhost:*"
      ],
      "webOrigins": [],
      "bearerOnly": false,
      "consentRequired": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "publicClient": true,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],

  "identityProviders": [
    {
      "alias": "github",
      "displayName": "GitHub",
      "providerId": "github",
      "enabled": true,
      "updateProfileFirstLoginMode": "on",
      "trustEmail": true,
      "storeToken": true,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${GITHUB_CLIENT_ID:-your-github-client-id}",
        "clientSecret": "${GITHUB_CLIENT_SECRET:-your-github-client-secret}",
        "defaultScope": "user:email read:user",
        "syncMode": "IMPORT"
      }
    },
    {
      "alias": "google",
      "displayName": "Google",
      "providerId": "google",
      "enabled": true,
      "updateProfileFirstLoginMode": "on",
      "trustEmail": true,
      "storeToken": true,
      "addReadTokenRoleOnCreate": false,
      "authenticateByDefault": false,
      "linkOnly": false,
      "firstBrokerLoginFlowAlias": "first broker login",
      "config": {
        "clientId": "${GOOGLE_CLIENT_ID:-your-google-client-id}",
        "clientSecret": "${GOOGLE_CLIENT_SECRET:-your-google-client-secret}",
        "defaultScope": "openid email profile",
        "syncMode": "IMPORT",
        "useJwksUrl": "true"
      }
    }
  ],

  "identityProviderMappers": [
    {
      "name": "github-username",
      "identityProviderAlias": "github",
      "identityProviderMapper": "github-user-attribute-mapper",
      "config": {
        "syncMode": "INHERIT",
        "jsonField": "login",
        "userAttribute": "github_username"
      }
    },
    {
      "name": "github-email",
      "identityProviderAlias": "github",
      "identityProviderMapper": "github-user-attribute-mapper",
      "config": {
        "syncMode": "INHERIT",
        "jsonField": "email",
        "userAttribute": "email"
      }
    },
    {
      "name": "google-email",
      "identityProviderAlias": "google",
      "identityProviderMapper": "oidc-user-attribute-idp-mapper",
      "config": {
        "syncMode": "INHERIT",
        "claim": "email",
        "user.attribute": "email"
      }
    }
  ],

  "users": [
    {
      "username": "c4-admin",
      "enabled": true,
      "email": "admin@c4.local",
      "firstName": "C4",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": true
        }
      ],
      "realmRoles": ["admin", "supervisor", "worker"]
    },
    {
      "username": "c4-worker",
      "enabled": true,
      "email": "worker@c4.local",
      "firstName": "C4",
      "lastName": "Worker",
      "credentials": [
        {
          "type": "password",
          "value": "worker",
          "temporary": true
        }
      ],
      "realmRoles": ["worker"]
    }
  ]
}

# =============================================================================
# Supabase Configuration for C4 Cloud
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file with real credentials!

# -----------------------------------------------------------------------------
# Supabase Project Settings
# -----------------------------------------------------------------------------
# Find these in: Supabase Dashboard > Settings > API

# Project URL (e.g., https://xxxx.supabase.co)
SUPABASE_URL=

# Public (anon) key - safe to use in client-side code
SUPABASE_ANON_KEY=

# Service role key - ONLY use on server-side, has admin access
# WARNING: Keep this secret!
SUPABASE_SERVICE_KEY=

# -----------------------------------------------------------------------------
# OAuth Providers (Optional - for development reference)
# -----------------------------------------------------------------------------
# These are configured in Supabase Dashboard, not in env vars
# Listed here for documentation purposes only

# GitHub OAuth (Settings > Authentication > Providers > GitHub)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth (Settings > Authentication > Providers > Google)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Local Development Override
# -----------------------------------------------------------------------------
# Use these when running `supabase start` locally

# SUPABASE_URL=http://localhost:54321
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -----------------------------------------------------------------------------
# C4 Cloud Settings
# -----------------------------------------------------------------------------

# API server URL (for web dashboard)
C4_API_URL=http://localhost:8000

# Enable debug mode
C4_DEBUG=false

# JWT secret for API tokens (generate with: openssl rand -hex 32)
C4_JWT_SECRET=

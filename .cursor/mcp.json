{
  "mcpServers": {
    "c4": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "${workspaceFolder}",
        "run",
        "python",
        "-m",
        "c4.mcp_server"
      ],
      "env": {
        "C4_PROJECT_ROOT": "${workspaceFolder}",
        "C4_LSP_ENABLED": "true",
        "C4_DAEMON_ENABLED": "true"
      }
    }
  }
}
